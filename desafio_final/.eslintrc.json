{
  "extends": "airbnb-base",
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "linebreak-style": "off",
    "no-console": "off",
    "import/no-commonjs": "off",
    "global-require": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|^next$|^error$|^erro$" }],
    "no-trailing-spaces": "warn",
    "padded-blocks": "off",
    "no-multiple-empty-lines": ["warn", { "max": 2 }]
  },
  "ignorePatterns": ["node_modules/", "src/db/migrations/"]
}
